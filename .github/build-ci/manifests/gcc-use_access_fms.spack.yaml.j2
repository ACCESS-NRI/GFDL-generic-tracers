spack:
  specs:
  # *_compiler is defined in the .github/build-ci/data/standard.json file
  - access-generic-tracers@git.{{ ref }} +use_access_fms
  packages:
    gcc:
      require:
        - '@{{ gcc_compiler_version }}'
    all:
      require:
      - '%access_gcc'
      - target=x86_64
  concretizer:
    unify: false
  view: false
